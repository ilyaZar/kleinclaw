{
  "name": "kleinclaw",
  "version": "0.2.2",
  "description": "Kleinanzeigen tools that can change live listings and run miniclaw with redacted output",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilyaZar/kleinclaw.git"
  },
  "bugs": {
    "url": "https://github.com/ilyaZar/kleinclaw/issues"
  },
  "homepage": "https://github.com/ilyaZar/kleinclaw#readme",
  "keywords": [
    "openclaw",
    "plugin",
    "kleinclaw",
    "kleinanzeigen"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "CHANGELOG.md",
    "examples/",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "index.js",
    "miniclaw/",
    "openclaw.plugin.json",
    "skills/",
    "src/"
  ],
  "scripts": {
    "build": "npm run build:miniclaw",
    "build:miniclaw": "tsc -p tsconfig.miniclaw.json",
    "coverage": "node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info",
    "package:check": "node --test test/package.test.js",
    "test": "node --test"
  },
  "dependencies": {
    "decimal.js": "^10.6.0",
    "glob": "^13.0.6",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.3-beta.3"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.3-beta.3",
      "minGatewayVersion": "2026.5.3-beta.3"
    },
    "build": {
      "openclawVersion": "2026.5.3-beta.3",
      "pluginSdkVersion": "2026.5.3-beta.3"
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^6.0.3"
  }
}
