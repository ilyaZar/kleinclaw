{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmitOnError": true,
    "outDir": "miniclaw/dist",
    "rootDir": "miniclaw/src",
    "skipLibCheck": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["miniclaw/src/**/*.ts"]
}
